generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum Categoria {
    ONLINE
    PRESENCIAL
    DELIVERY
    RETIRADA
}

model Cliente {
    id         Int     @id @default(autoincrement())
    nome       String
    email      String?
    telefone   String?
    cep        String? @db.Char(9)
    logradouro String?
    bairro     String?
    localidade String?
    uf         String?
    ativo      Boolean @default(true)

    pedidos Pedido[]

    @@map("cliente")
}

model Pedido {
    id         Int       @id @default(autoincrement())
    nome       String
    descricao  String?
    categoria  Categoria
    disponivel Boolean   @default(true)
    preco      Decimal   @db.Decimal(10, 2)
    foto       String?

    clienteId Int
    cliente   Cliente @relation(fields: [clienteId], references: [id])

    @@map("pedido")
}
